{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "db://assets/*": ["assets/*"]
    }
  },
  "include": ["assets/scripts/**/*.ts"],
  "exclude": ["temp", "library", "build", "local"]
}
